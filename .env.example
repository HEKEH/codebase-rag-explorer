# LLM
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=

# Server
PORT=5001
HOST=0.0.0.0
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Database
DB_PATH=./data/codebase-rag.db

# Embedding Model
EMBEDDING_MODEL=./models/nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DIMENSION=768

# LLM Model
LLM_MODEL=claude-sonnet-4-6

# Chunking
CHUNK_MAX_LENGTH=1500
CHUNK_OVERLAP=200

# Retrieval
DEFAULT_TOP_K=5
MAX_CONTEXT_TOKENS=8000
# BM25 candidate depth (sparse / FTS path; see retrieval-enhancement-roadmap P1-5)
RETRIEVAL_BM25_TOP_N=20
# Dense (vector) candidate depth; leave empty for legacy max(topK*3, topK)
# RETRIEVAL_DENSE_TOP_N=15
# Fusion: weighted (min-max linear, default) | rrf (case/whitespace-insensitive, e.g. RRF)
# RETRIEVAL_FUSION=weighted
# RRF constant k (default 60 in @repo/constants)
# RETRIEVAL_RRF_K=60
# RRF: BM25 rank term scale when intent is explain (locate uses 1); clamped 0–RETRIEVAL_RRF_WEIGHT_ABS_MAX (default 2 in @repo/constants), default weight 0.35 in @repo/constants
# RETRIEVAL_RRF_EXPLAIN_BM25_WEIGHT=0.35
# RETRIEVAL_QUERY_MODALITY=auto
#   auto — 启发式判别 NL vs PL（`apps/server/src/lib/query-modality.ts`）
#   force_nl | force_pl — 固定内容模态，覆盖 auto（运维纠偏；见 retrieval-enhancement-design §3.C、路线图 Phase 3）
# Sparse candidate source: fts (BM25 on chunk_fts, default) | full_table (legacy repo-wide scan)
RETRIEVAL_SPARSE_MODE=fts
