{
  "name": "@repo/server",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "sh -c 'ENV_FILE=.env; [ -f \"$ENV_FILE\" ] || ENV_FILE=../../.env; bun --env-file=\"$ENV_FILE\" run --watch src/index.ts'",
    "postinstall": "sh -c 'ENV_FILE=.env; [ -f \"$ENV_FILE\" ] || ENV_FILE=../../.env; bun --env-file=\"$ENV_FILE\" ./src/scripts/download-embedding-model.ts || true'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "sh -c 'TMP_DIR=$(mktemp -d); DB_PATH=\"$TMP_DIR/codebase-rag.db\" bun test; EXIT_CODE=$?; rm -rf \"$TMP_DIR\"; exit $EXIT_CODE'"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@langchain/anthropic": "^1.3.27",
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.41",
    "@langchain/textsplitters": "^1.0.1",
    "@repo/constants": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/types": "workspace:*",
    "@huggingface/hub": "^2.11.0",
    "@xenova/transformers": "^2.17.2",
    "elysia": "^1.4.0",
    "langchain": "^1.3.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "bun-types": "latest",
    "typescript": "^5.6.3"
  }
}
